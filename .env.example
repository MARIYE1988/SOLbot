# Solana RPC endpoint (use a private RPC for production)
RPC_URL=https://api.mainnet-beta.solana.com

# Base-58 encoded wallet private key
PRIVATE_KEY=

# HYPE token mint address on Solana mainnet
HYPE_MINT=

# Price move (as a decimal) that triggers a swap — 0.05 = 5%
TRIGGER_DELTA=0.05

# SOL amount to swap each time the trigger fires
SWAP_AMOUNT_SOL=0.01

# Slippage tolerance in basis points (50 = 0.5%)
SLIPPAGE_BPS=50

# How often to poll the price, in milliseconds (30000 = 30 s)
POLL_INTERVAL_MS=30000
